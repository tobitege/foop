<Window x:Class="Foop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Foop"
        Icon="{StaticResource FoopIcon}"
        Width="760"
        Height="620"
        MinWidth="580"
        MinHeight="440"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Activated="OnActivated"
        Closing="OnClosing">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="Background" Value="#172554" />
        </Style>
        <Style x:Key="WindowListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="Foop" />
                <TextBlock Margin="0,6,0,0" Opacity="0.72"
                           Text="Fenster auswählen und auf diesen Monitor holen." />
            </StackPanel>
            <Button Grid.Column="1" Padding="14,8" VerticalAlignment="Center"
                    AutomationProperties.Name="Fensterliste aktualisieren"
                    Click="OnRefreshClick" Content="Aktualisieren" />
        </Grid>

        <Border Grid.Row="1" Margin="0,22,0,18"
                TextElement.Foreground="#F8FAFC"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="42" Height="42" CornerRadius="10" Background="#2563EB">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons" FontSize="20"
                               Foreground="White" Text="&#xE7F4;" />
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Opacity="0.68" Text="ZIELMONITOR" />
                    <TextBlock x:Name="TargetMonitorText" Margin="0,3,0,0"
                               FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock x:Name="MonitorCountText" Grid.Column="2"
                           VerticalAlignment="Center" Opacity="0.68" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="2,0,2,10">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Aktive Desktop-Apps" />
                <TextBlock x:Name="WindowCountText" HorizontalAlignment="Right" Opacity="0.68" />
            </Grid>
            <ListBox x:Name="WindowListBox" Grid.Row="1" BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource WindowListItemStyle}"
                     SelectionChanged="OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     AutomationProperties.Name="Aktive Desktop-Apps">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" CornerRadius="8" Background="#2563EB">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="SemiBold" Foreground="White" Text="{Binding Initial}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0" FontSize="12" Opacity="0.65"
                                           Text="{Binding ProcessDisplayName}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.55" Text="{Binding StateLabel}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" MaxWidth="470" VerticalAlignment="Center"
                       Opacity="0.72" TextWrapping="Wrap" />
            <Button x:Name="FoopButton" Grid.Column="1" MinWidth="130" Padding="22,11"
                    FontSize="15" FontWeight="SemiBold" IsDefault="True" IsEnabled="False"
                    AutomationProperties.Name="Ausgewähltes Fenster auf den Zielmonitor verschieben"
                    Click="OnFoopClick" Content="Foop!" />
        </Grid>
    </Grid>
</Window>
