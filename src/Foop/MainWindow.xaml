<Window x:Class="Foop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Foop"
        Icon="{StaticResource FoopIcon}"
        Width="760"
        Height="620"
        MinWidth="580"
        MinHeight="440"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Activated="OnActivated"
        StateChanged="OnStateChanged"
        Closing="OnClosing">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="Background" Value="#172554" />
        </Style>
        <Style x:Key="WindowListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="WindowGridItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Width" Value="200" />
            <Setter Property="MaxWidth" Value="200" />
        </Style>
        <Style x:Key="IconChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#172554" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <LinearGradientBrush x:Key="FoopButtonFaceBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#2563EB" Offset="0.55" />
            <GradientStop Color="#1D4ED8" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FoopButtonFaceHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#60A5FA" Offset="0" />
            <GradientStop Color="#3B82F6" Offset="0.55" />
            <GradientStop Color="#2563EB" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FoopButtonFacePressedBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1E40AF" Offset="0" />
            <GradientStop Color="#1D4ED8" Offset="0.45" />
            <GradientStop Color="#1E3A8A" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="FoopActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Depth"
                                    Margin="0,3,0,0"
                                    CornerRadius="10"
                                    Background="#0B1F4A" />
                            <Border x:Name="Face"
                                    Margin="0,0,0,3"
                                    CornerRadius="10"
                                    BorderThickness="1.5"
                                    BorderBrush="#93C5FD"
                                    Background="{StaticResource FoopButtonFaceBrush}">
                                <Border x:Name="Highlight"
                                        CornerRadius="8"
                                        Margin="1"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#BFDBFE">
                                    <ContentPresenter x:Name="Content"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Face" Property="BorderBrush" Value="#DBEAFE" />
                                <Setter TargetName="Face" Property="Background"
                                        Value="{StaticResource FoopButtonFaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Margin" Value="0,3,0,0" />
                                <Setter TargetName="Depth" Property="Margin" Value="0" />
                                <Setter TargetName="Face" Property="BorderBrush" Value="#1E3A8A" />
                                <Setter TargetName="Face" Property="Background"
                                        Value="{StaticResource FoopButtonFacePressedBrush}" />
                                <Setter TargetName="Highlight" Property="BorderBrush" Value="#1E3A8A" />
                                <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1" />
                                <Setter TargetName="Content" Property="Margin" Value="19,12,17,8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Face" Property="Opacity" Value="0.28" />
                                <Setter TargetName="Depth" Property="Opacity" Value="0.2" />
                                <Setter TargetName="Face" Property="BorderBrush" Value="#334155" />
                                <Setter TargetName="Highlight" Property="BorderBrush" Value="#334155" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MonitorPreferenceBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="ToolTip" Value="{Binding PreferredMonitorToolTip}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PreferredMonitorNumber}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="DetailItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" HorizontalAlignment="Left"
                        VerticalAlignment="Center" CornerRadius="8" Background="#2563EB">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="SemiBold" Foreground="White" Text="{Binding Initial}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,12,0">
                    <TextBlock FontWeight="SemiBold" Text="{Binding PrimaryLabel}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,3,0,0" FontSize="12" Opacity="0.65"
                               Text="{Binding SecondaryLabel}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12" Opacity="0.55" Text="{Binding StateLabel}" />
                    <Border Margin="8,0,0,0"
                            Style="{StaticResource MonitorPreferenceBadgeStyle}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="Bold" Foreground="White"
                                   Text="{Binding PreferredMonitorNumber}" />
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="GridItemTemplate">
            <Border Padding="12" CornerRadius="10" BorderThickness="1"
                    BorderBrush="#1D4ED8" Background="#172554"
                    MaxWidth="200">
                <Grid>
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="10" Background="#2563EB"
                                HorizontalAlignment="Left">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="16" Foreground="White"
                                       Text="{Binding Initial}" />
                        </Border>
                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold"
                                   Text="{Binding PrimaryLabel}" TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Margin="0,4,0,0" FontSize="11" Opacity="0.65"
                                   Text="{Binding SecondaryLabel}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,6,0,0" FontSize="11" Opacity="0.55"
                                   Text="{Binding StateLabel}" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Style="{StaticResource MonitorPreferenceBadgeStyle}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="Bold" Foreground="White"
                                   Text="{Binding PreferredMonitorNumber}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <ItemsPanelTemplate x:Key="DetailItemsPanel">
            <VirtualizingStackPanel />
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="GridItemsPanel">
            <WrapPanel />
        </ItemsPanelTemplate>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="ViewModeComboBox"
                          Width="116"
                          Height="36"
                          ToolTip="View"
                          AutomationProperties.Name="View"
                          SelectionChanged="OnViewModeChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14"
                                           VerticalAlignment="Center" Text="{Binding IconGlyph}" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Margin="8,0,0,0"
                        Style="{StaticResource IconChromeButtonStyle}"
                        ToolTip="Settings"
                        AutomationProperties.Name="Settings"
                        Click="OnSettingsClick">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16"
                               Foreground="White" Text="&#xE713;" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="16,0,16,0">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="Foop" />
                <TextBlock Margin="0,6,0,0" Opacity="0.72"
                           Text="Select a window and bring it onto this monitor." />
            </StackPanel>
            <Button Grid.Column="2" Padding="14,8" VerticalAlignment="Center"
                    AutomationProperties.Name="Refresh window list"
                    Click="OnRefreshClick" Content="Refresh" />
        </Grid>

        <Border Grid.Row="1" Margin="0,22,0,18"
                TextElement.Foreground="#F8FAFC"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="42" Height="42" CornerRadius="10" Background="#2563EB">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons" FontSize="20"
                               Foreground="White" Text="&#xE7F4;" />
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Opacity="0.68" Text="TARGET MONITOR" />
                    <TextBlock x:Name="TargetMonitorText" Margin="0,3,0,0"
                               FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock x:Name="MonitorCountText" Grid.Column="2"
                           VerticalAlignment="Center" Opacity="0.68" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="2,0,2,10">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Active desktop apps" />
                <TextBlock x:Name="WindowCountText" HorizontalAlignment="Right" Opacity="0.68" />
            </Grid>
            <ListBox x:Name="WindowListBox" Grid.Row="1" BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource WindowListItemStyle}"
                     ItemTemplate="{StaticResource DetailItemTemplate}"
                     ItemsPanel="{StaticResource DetailItemsPanel}"
                     SelectionChanged="OnSelectionChanged"
                     MouseDoubleClick="OnWindowListDoubleClick"
                     PreviewMouseRightButtonUp="OnWindowListRightClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     AutomationProperties.Name="Active desktop apps" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" MaxWidth="470" VerticalAlignment="Center"
                       Opacity="0.72" TextWrapping="Wrap" />
            <Button x:Name="FoopButton" Grid.Column="1"
                    Style="{StaticResource FoopActionButtonStyle}"
                    IsDefault="True" IsEnabled="False"
                    AutomationProperties.Name="Move the selected window onto the target monitor"
                    Click="OnFoopClick">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{StaticResource FoopIcon}" Width="20" Height="20"
                           VerticalAlignment="Center" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="White" Text="Foop!" />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock Grid.Row="4" Margin="0,14,0,0" FontSize="12" Opacity="0.62"
                   HorizontalAlignment="Center" TextAlignment="Center">
            <Hyperlink NavigateUri="https://github.com/tobitege/foop"
                       RequestNavigate="OnRepoLinkRequestNavigate">
                https://github.com/tobitege/foop
            </Hyperlink>
            <Run Text="  ·  MIT licensed" />
        </TextBlock>
    </Grid>
</Window>
