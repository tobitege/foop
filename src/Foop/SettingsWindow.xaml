<Window x:Class="Foop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Icon="{StaticResource FoopIcon}"
        Width="420"
        MinWidth="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="#0F172A">
    <Window.Resources>
        <Style x:Key="SettingsCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="22" Height="22"
                                    CornerRadius="6"
                                    BorderThickness="1.5"
                                    BorderBrush="#60A5FA"
                                    Background="#172554"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           Foreground="White"
                                           Text="&#xE73E;"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#93C5FD" />
            <Setter Property="Margin" Value="2,0,0,10" />
        </Style>
        <Style x:Key="SettingsGroupBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="Background" Value="#172554" />
        </Style>
        <Style x:Key="SettingsActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#1E3A8A" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Border Width="36" Height="36" CornerRadius="10" Background="#2563EB">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Segoe Fluent Icons" FontSize="18"
                           Foreground="White" Text="&#xE713;" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" Text="Settings" />
                <TextBlock Margin="0,2,0,0" FontSize="12" Opacity="0.65"
                           Foreground="#F8FAFC" Text="Options are saved for this Windows user." />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,22,0,0">
            <TextBlock Style="{StaticResource SettingsGroupTitleStyle}" Text="Options" />
            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                <StackPanel>
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="Start with Windows" />
                    <CheckBox x:Name="StartMinimizedCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="Start minimized" />
                    <CheckBox x:Name="MinimizeToTrayCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="Minimize to Tray" />
                    <CheckBox x:Name="CloseToTrayCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="Close to Tray" />
                    <CheckBox x:Name="AutoMinimizeOnFoopingCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="Auto-Minimize on Fooping" />
                    <CheckBox x:Name="ListByApplicationNameCheckBox"
                              Style="{StaticResource SettingsCheckBoxStyle}"
                              Content="List by application name"
                              Margin="0" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource SettingsGroupTitleStyle}" Text="Actions" />
            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                <Button Style="{StaticResource SettingsActionButtonStyle}"
                        Click="OnCreateStartMenuIconClick"
                        AutomationProperties.Name="Create Start Menu icon">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource FoopIcon}" Width="18" Height="18"
                               VerticalAlignment="Center" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                   Text="Create Start Menu icon…" />
                    </StackPanel>
                </Button>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,22,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource DialogButtonStyle}"
                    IsDefault="True"
                    Click="OnSaveClick"
                    Content="Save" />
            <Button Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True"
                    Click="OnCancelClick"
                    Content="Cancel" />
        </StackPanel>

        <TextBlock x:Name="VersionText" Grid.Row="4"
                   Margin="0,16,0,0"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Opacity="0.48"
                   Foreground="#F8FAFC" />
    </Grid>
</Window>
