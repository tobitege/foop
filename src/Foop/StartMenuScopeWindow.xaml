<Window x:Class="Foop.StartMenuScopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Start Menu icon"
        Icon="{StaticResource FoopIcon}"
        Width="420"
        MinWidth="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="#0F172A">
    <Window.Resources>
        <Style x:Key="ScopeRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="StartMenuScope" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Outer"
                                    Width="22" Height="22"
                                    CornerRadius="11"
                                    BorderThickness="1.5"
                                    BorderBrush="#60A5FA"
                                    Background="#172554"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0">
                                <Ellipse x:Name="Dot"
                                         Width="10" Height="10"
                                         Fill="White"
                                         Visibility="Collapsed" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <ContentPresenter RecognizesAccessKey="True" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Outer" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Image Source="{StaticResource FoopIcon}" Width="28" Height="28"
                   VerticalAlignment="Center" />
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F8FAFC"
                           Text="Create Start Menu icon" />
                <TextBlock Margin="0,4,0,0" FontSize="12" Opacity="0.68" Foreground="#F8FAFC"
                           TextWrapping="Wrap"
                           Text="Choose who should see the Foop shortcut in the Start menu." />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,22,0,0" Padding="18"
                CornerRadius="12" BorderThickness="1"
                BorderBrush="#1D4ED8" Background="#172554">
            <StackPanel>
                <RadioButton x:Name="CurrentUserRadioButton"
                             Style="{StaticResource ScopeRadioButtonStyle}"
                             IsChecked="True">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Only for me" />
                        <TextBlock Margin="0,3,0,0" FontSize="12" Opacity="0.68"
                                   Text="Current user Start menu" />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="AllUsersRadioButton"
                             Style="{StaticResource ScopeRadioButtonStyle}"
                             Margin="0">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="For all users" />
                        <TextBlock Margin="0,3,0,0" FontSize="12" Opacity="0.68"
                                   Text="Requires administrator rights" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,22,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource DialogButtonStyle}"
                    IsDefault="True"
                    Click="OnCreateClick"
                    Content="Create" />
            <Button Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True"
                    Click="OnCancelClick"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
