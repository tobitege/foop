<Window x:Class="Foop.AppActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App actions"
        Icon="{StaticResource FoopIcon}"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="#0F172A">
    <Window.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#93C5FD" />
            <Setter Property="Margin" Value="2,0,0,10" />
        </Style>
        <Style x:Key="MonitorButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#1E3A8A" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="42" Height="42" CornerRadius="10" Background="#2563EB">
                <TextBlock x:Name="AppInitialText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </Border>
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="AppNameText"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="AppDetailText"
                           Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="#F8FAFC"
                           Opacity="0.65"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,22,0,0"
                      MaxHeight="520"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Send to screen" />
                <Border Padding="16" CornerRadius="12" BorderThickness="1"
                        BorderBrush="#1D4ED8" Background="#172554">
                    <StackPanel x:Name="SendButtonsPanel" />
                </Border>

                <TextBlock Margin="2,18,0,10"
                           Style="{StaticResource SectionTitleStyle}"
                           Text="Always move to screen" />
                <Border Padding="16" CornerRadius="12" BorderThickness="1"
                        BorderBrush="#1D4ED8" Background="#172554">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,12"
                                   FontSize="12"
                                   Foreground="#F8FAFC"
                                   Opacity="0.68"
                                   Text="Applies when the first instance of this app starts."
                                   TextWrapping="Wrap" />
                        <StackPanel x:Name="AlwaysMoveButtonsPanel" />
                        <Button x:Name="DisableRuleButton"
                                Margin="0"
                                Style="{StaticResource MonitorButtonStyle}"
                                Click="OnDisableRuleClick"
                                Content="Off" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Margin="0,22,0,0"
                HorizontalAlignment="Right"
                Style="{StaticResource CloseButtonStyle}"
                IsCancel="True"
                Content="Close" />
    </Grid>
</Window>
